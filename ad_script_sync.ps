Import-Module ActiveDirectory

$LogDate  = Get-Date -Format "yyyyMMddHHmm"
$CsvFile  = "AD_MstMember_$LogDate.csv"

$SearchBase = "DC=ad,DC=bio-experience,DC=com"

$OrganizationId = "4F43B0FE-1295-42D1-AF41-BB8D7F28A101"
$DepartmentId   = "D1ED0C3A-4019-45BF-8CB9-DD8BF4CDC3D4"
$DistrictId     = "C0C18BED-F68D-40C1-82D9-FC09E04168F9"

Get-ADUser -SearchBase $SearchBase -Filter * -Properties * |
Select-Object `
    @{Label='OrganizationId'; Expression={ $OrganizationId }},
    @{Label='DepartmentId';   Expression={ $DepartmentId }},
    @{Label='DistrictId';     Expression={ $DistrictId }},
    @{Label='PersonId';       Expression={ $_.sAMAccountName }},
    @{Label='IdentityId';     Expression={ if ($_.employeeID) { $_.employeeID } else { $_.sAMAccountName } }},
    @{Label='Name';           Expression={ "$($_.GivenName) $($_.Surname)" }},
    @{Label='Email';          Expression={ $_.Mail }},
    @{Label='Phone';          Expression={ if ($_.Mobile) { $_.Mobile } else { $_.telephoneNumber } }},
    @{Label='Gender';         Expression={ "" }},
    @{Label='StatusEmployee'; Expression={ "active" }},
    @{Label='Address';        Expression={
        ($_.streetAddress, $_.l, $_.st, $_.postalCode |
            Where-Object { $_ -and $_.Trim() -ne "" }) -join ", "
    }},
    @{Label='CardNumber';     Expression={ "" }},
    @{Label='BirthDate';      Expression={ "" }},
    @{Label='JoinDate';       Expression={ "" }} |
Export-Csv -Path $CsvFile -NoTypeInformation -Encoding UTF8

Write-Host "CSV generated: $CsvFile"

$ApiUrl = "https://ble.local:4430/api/MstMember/import-csv"

$BearerToken = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..DmYwrcaEXefiVu_hmgmn_OG8Za6quolCoKmdCHBnISw"

$ApiKey = "FujDuGTsyEXVwkKrtRgn52APwAVRGmPOiIRX8cffynDvIW35bJaGeH3NcH6HcSeK"

$Headers = @(
    "-H", "Authorization: Bearer $BearerToken",
    "-H", "X-BIOPEOPLETRACKING-API-KEY: $ApiKey"
)

curl.exe `
    -k `
    -X POST $ApiUrl `
    -F "file=@$CsvFile" `
    $Headers

Write-Host "AD sync triggered"
